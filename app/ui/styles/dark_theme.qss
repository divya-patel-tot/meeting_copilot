/* Meeting Responder — glassmorphism copilot overlay theme */

QWidget {
    background-color: transparent;
    color: #e6eaf0;
    font-family: "Segoe UI Variable", "Segoe UI", sans-serif;
    font-size: 13px;
}

QMainWindow {
    background-color: #12141c;
}

/* ── Glass card shell ── */

QWidget#glassCard {
    background-color: #12141c;
    border: none;
    border-radius: 0;
}

QWidget#glassCardBody {
    background: transparent;
}

/* ── Custom title bar ── */

QWidget#customTitleBar {
    background-color: #161922;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

QWidget#appIconDot {
    background-color: #4a90d9;
    border-radius: 5px;
}

QLabel#titleBarLabel {
    color: #eef2f8;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.3px;
}

QPushButton#titleBarButton {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    color: #b8c0cc;
    font-size: 16px;
    font-weight: 400;
    padding: 0;
}

QPushButton#titleBarButton:hover {
    background-color: rgba(255, 255, 255, 0.08);
    color: #ffffff;
}

QPushButton#titleBarCloseButton {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    color: #b8c0cc;
    font-size: 18px;
    font-weight: 400;
    padding: 0;
}

QPushButton#titleBarCloseButton:hover {
    background-color: #e74c3c;
    color: #ffffff;
}

/* ── Controls row ── */

QLabel#controlLabel {
    color: #9aa4b2;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
}

QLabel#captureInfoLabel {
    color: #c8d4ea;
    font-size: 13px;
    line-height: 1.4;
}

QPushButton#secondaryButton {
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: #d8dee9;
    font-size: 13px;
    font-weight: 600;
    padding: 7px 14px;
}

QPushButton#secondaryButton:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: rgba(74, 144, 217, 0.5);
}

QPushButton#linkButton {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    color: #8ab4ff;
    font-size: 12px;
    font-weight: 600;
    padding: 2px 6px;
    text-align: left;
}

QPushButton#linkButton:hover {
    color: #b3ccff;
    background-color: rgba(255, 255, 255, 0.05);
}

QPushButton#linkButton:checked {
    color: #c8d8ff;
}

QComboBox {
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9px;
    padding: 7px 12px;
    color: #e6eaf0;
    font-size: 13px;
}

QComboBox:hover {
    border-color: rgba(74, 144, 217, 0.55);
    background-color: rgba(255, 255, 255, 0.08);
}

QComboBox::drop-down {
    border: none;
    width: 24px;
}

QComboBox QAbstractItemView {
    background-color: #1e222c;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    color: #e6eaf0;
    selection-background-color: rgba(74, 144, 217, 0.35);
    padding: 4px;
}

QPushButton#startStopButton {
    background-color: #2ecc71;
    color: #0f1419;
    border: none;
    border-radius: 9px;
    padding: 8px 18px;
    font-size: 13px;
    font-weight: 700;
}

QPushButton#startStopButton:hover {
    background-color: #3ddb84;
}

QPushButton#startStopButton:pressed {
    background-color: #27ae60;
}

QPushButton#startStopButton[listening="true"] {
    background-color: #e74c3c;
    color: #ffffff;
}

QPushButton#startStopButton[listening="true"]:hover {
    background-color: #f05a4a;
}

QPushButton#startStopButton[listening="true"]:pressed {
    background-color: #c0392b;
}

QPushButton:disabled {
    background-color: rgba(255, 255, 255, 0.06);
    color: #6a7380;
}

/* ── Status pill ── */

QWidget#statusPill {
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
}

QWidget#statusPill[listening="true"] {
    background-color: rgba(46, 204, 113, 0.12);
    border-color: rgba(46, 204, 113, 0.35);
}

QWidget#statusDot {
    background-color: #7a8494;
    border-radius: 4px;
}

QWidget#statusPill[listening="true"] QWidget#statusDot {
    background-color: #2ecc71;
}

QLabel#statusPillLabel {
    color: #c8d0dc;
    font-size: 12px;
    font-weight: 600;
}

QWidget#statusPill[listening="true"] QLabel#statusPillLabel {
    color: #b8f0c8;
}

/* ── Glass sub-panels ── */

QWidget#transcriptGlassPanel {
    background-color: rgba(20, 24, 32, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
}

QWidget#suggestionGlassPanel {
    background-color: rgba(18, 26, 20, 0.72);
    border: 1px solid rgba(46, 204, 113, 0.18);
    border-radius: 12px;
}

QWidget#panelContent {
    background: transparent;
}

QLabel#panelHeading {
    color: #8ab4ff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.4px;
}

QWidget#suggestionGlassPanel QLabel#panelHeading {
    color: #7dcea0;
}

QSplitter#mainSplitter::handle {
    background-color: rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    margin: 6px 2px;
}

QSplitter#mainSplitter::handle:hover {
    background-color: rgba(74, 144, 217, 0.45);
}

QTextEdit#transcriptPanel,
QTextBrowser#transcriptPanel {
    background-color: rgba(20, 24, 32, 0.55);
    border: none;
    border-radius: 8px;
    padding: 10px 12px;
    color: #d8dee9;
    font-size: 14px;
    line-height: 1.45;
    selection-background-color: rgba(74, 144, 217, 0.35);
}

QTextBrowser#transcriptPanel::hover {
    border: none;
}

QTextEdit#suggestionPanel {
    background-color: rgba(18, 26, 20, 0.55);
    border: none;
    border-radius: 8px;
    padding: 8px 10px;
    color: #d4ecd8;
    font-size: 14px;
    selection-background-color: rgba(45, 106, 79, 0.55);
}

QTextEdit#debugPanel {
    background-color: rgba(28, 24, 36, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    padding: 8px 10px;
    color: #b8a8d0;
    font-family: Consolas, "Cascadia Mono", monospace;
    font-size: 11px;
}

QCheckBox {
    color: #9aa4b2;
    spacing: 8px;
    font-size: 12px;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 4px;
    background-color: rgba(255, 255, 255, 0.06);
}

QCheckBox::indicator:checked {
    background-color: #4a90d9;
    border-color: #4a90d9;
}

QCheckBox::indicator:hover {
    border-color: rgba(74, 144, 217, 0.6);
}

/* ── Scrollbars ── */

QScrollBar:vertical {
    background: transparent;
    width: 8px;
    margin: 4px 2px;
}

QScrollBar::handle:vertical {
    background: rgba(255, 255, 255, 0.14);
    border-radius: 4px;
    min-height: 28px;
}

QScrollBar::handle:vertical:hover {
    background: rgba(74, 144, 217, 0.55);
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical,
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
    height: 0;
}

/* ── Setup wizard (unchanged palette, glass-friendly) ── */

QLabel#setupHeading {
    color: #8ab4ff;
    font-size: 16px;
    font-weight: 700;
    padding-bottom: 8px;
}

QGroupBox {
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    margin-top: 12px;
    padding-top: 8px;
    color: #c8d0dc;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 4px;
    color: #8ab4ff;
}

QListWidget {
    background-color: rgba(20, 24, 32, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: #d8dee9;
}

QDialog {
    background-color: #1a1d23;
    color: #e6eaf0;
}

QLineEdit {
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    padding: 8px 10px;
    color: #e6eaf0;
}

QPushButton {
    background-color: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: #e6eaf0;
    padding: 7px 14px;
}

QPushButton:hover {
    border-color: rgba(74, 144, 217, 0.5);
}

QProgressBar {
    background-color: rgba(255, 255, 255, 0.06);
    border: none;
    border-radius: 6px;
    height: 8px;
    text-align: center;
}

QProgressBar::chunk {
    background: qlineargradient(
        x1: 0, y1: 0, x2: 1, y2: 0,
        stop: 0 #4a90d9,
        stop: 1 #2ecc71
    );
    border-radius: 6px;
}
